rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function hasAdminIdentity() {
      return request.auth.token.admin == true ||
             request.auth.token.email == 'hunaruhub@gmail.com';
    }
    function isAdmin() {
      return isSignedIn() && (
        hasAdminIdentity() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        userRole() == 'platform-admin'
      );
    }
    function userRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'recreational-diver';
    }
    function canPublishDiveSiteInfo() {
      return isAdmin() || userRole() in [
        'dive-professional',
        'dive-centre-manager',
        'marine-science-reviewer',
        'platform-admin'
      ];
    }

    function canReviewDiveSiteSuggestions() {
      return canPublishDiveSiteInfo();
    }

    function hasIndividualPro(userId) {
      return exists(/databases/$(database)/documents/proSubscriptions/$(userId)) &&
             get(/databases/$(database)/documents/proSubscriptions/$(userId)).data.status == 'active' &&
             get(/databases/$(database)/documents/proSubscriptions/$(userId)).data.tier == 'individual-diver-pro';
    }

    function hasDiveCentrePro(userId, centreId) {
      return exists(/databases/$(database)/documents/proSubscriptions/$(userId)) &&
             get(/databases/$(database)/documents/proSubscriptions/$(userId)).data.status == 'active' &&
             get(/databases/$(database)/documents/proSubscriptions/$(userId)).data.tier == 'dive-centre-pro' &&
             get(/databases/$(database)/documents/proSubscriptions/$(userId)).data.diveCentreId == centreId;
    }

    function isValidDiveSite(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.atoll is string && data.atoll.size() > 0 &&
             data.difficulty in ['beginner', 'intermediate', 'advanced', 'unknown'] &&
             (data.id == null || data.id is string && data.id.size() <= 128) &&
             (data.islandBase == null || data.islandBase is string && data.islandBase.size() <= 100) &&
             (data.region == null || data.region in ['north', 'central', 'south']) &&
             (data.type == null || data.type is string && data.type.size() <= 80) &&
             (data.depthMin == null || data.depthMin is number && data.depthMin >= 0 && data.depthMin <= 100) &&
             (data.depthMax == null || data.depthMax is number && data.depthMax >= 0 && data.depthMax <= 100) &&
             (data.current == null || data.current in ['none', 'mild', 'moderate', 'strong', 'very strong', 'unknown']) &&
             (data.visibility == null || data.visibility is string && data.visibility.size() <= 40) &&
             (data.coordinates == null || data.coordinates is map) &&
             (data.marineLifeHighlights == null || data.marineLifeHighlights is list && data.marineLifeHighlights.size() <= 20) &&
             (data.description == null || data.description is string && data.description.size() <= 1000) &&
             (data.bestSeason == null || data.bestSeason is string && data.bestSeason.size() <= 100) &&
             (data.isProtected == null || data.isProtected is bool) &&
             (data.regulatedAccess == null || data.regulatedAccess is bool) &&
             (data.protectedStatus == null || data.protectedStatus is string && data.protectedStatus.size() <= 100) &&
             (data.localName == null || data.localName is string && data.localName.size() <= 100) &&
             (data.notes == null || data.notes is string && data.notes.size() <= 500) &&
             (data.sourceName == null || data.sourceName is string && data.sourceName.size() <= 80) &&
             (data.sourceUrl == null || data.sourceUrl is string && data.sourceUrl.size() <= 1024) &&
             (data.sourceAtoll == null || data.sourceAtoll is string && data.sourceAtoll.size() <= 100) &&
             (data.dataQuality == null || data.dataQuality in ['name-atoll-only', 'feature-tagged', 'detailed']) &&
             (data.importedAt == null || data.importedAt is string) &&
             (data.descriptionSourceRefs == null || data.descriptionSourceRefs is list && data.descriptionSourceRefs.size() <= 10) &&
             (data.descriptionGeneratedAt == null || data.descriptionGeneratedAt is string) &&
             (data.descriptionGeneratedBy == null || data.descriptionGeneratedBy is string) &&
             (data.sketchInstructions == null || data.sketchInstructions is string && data.sketchInstructions.size() <= 2000) &&
             (data.sketchInstructionsUpdatedAt == null || data.sketchInstructionsUpdatedAt is string) &&
             (data.aiSketchUrl == null || data.aiSketchUrl is string && data.aiSketchUrl.size() <= 1024) &&
             (data.aiSketchPrompt == null || data.aiSketchPrompt is string && data.aiSketchPrompt.size() <= 4000) &&
             (data.aiSketchGeneratedAt == null || data.aiSketchGeneratedAt is string) &&
             (data.updatedAt == null || data.updatedAt is string) &&
             (data.createdAt == null || data.createdAt is string);
    }

    function isValidMarineLife(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.scientificName is string && data.scientificName.size() <= 100 &&
             data.category in ['Shark', 'Ray', 'Fish', 'Macro', 'Reptile', 'Other'] &&
             (data.description == null || data.description is string && data.description.size() <= 1000) &&
             (data.rarity == null || data.rarity in ['Common', 'Uncommon', 'Rare', 'Legendary']) &&
             (data.updatedAt == null || data.updatedAt is string) &&
             (data.createdAt == null || data.createdAt is string);
    }

    function isValidDiveLog(data) {
      return data is map &&
             data.userId == request.auth.uid &&
             (data.id == null || data.id is string && data.id.size() <= 128) &&
             (data.syncStatus == null || data.syncStatus in ['synced', 'pending']) &&
             data.date is string && data.date.size() == 10 &&
             (data.startTime == null || data.startTime is string && data.startTime.size() <= 20) &&
             data.siteId is string && data.siteId.size() <= 128 &&
             (data.customSiteName == null || data.customSiteName is string && data.customSiteName.size() <= 120) &&
             (data.atoll == null || data.atoll is string && data.atoll.size() <= 80) &&
             (data.island == null || data.island is string && data.island.size() <= 100) &&
             (data.current == null || data.current in ['none', 'mild', 'moderate', 'strong', 'very strong', 'unknown']) &&
             (data.entryType == null || data.entryType in ['boat', 'shore', 'jetty']) &&
             (data.diveTypes == null || data.diveTypes is list && data.diveTypes.size() <= 20) &&
             (data.gasType == null || data.gasType is string && data.gasType.size() <= 40) &&
             (data.tankSize == null || data.tankSize is number && data.tankSize >= 1 && data.tankSize <= 30) &&
             (data.sac == null || data.sac is number && data.sac >= 0 && data.sac <= 100) &&
             (data.surfaceInterval == null || data.surfaceInterval is number && data.surfaceInterval >= 0 && data.surfaceInterval <= 10000) &&
             (data.safetyStop == null || data.safetyStop is bool) &&
             (data.buddyNames == null || data.buddyNames is list && data.buddyNames.size() <= 20) &&
             (data.diveCenter == null || data.diveCenter is string && data.diveCenter.size() <= 120) &&
             (data.instructorName == null || data.instructorName is string && data.instructorName.size() <= 120) &&
             (data.isVerified == null || data.isVerified is bool) &&
             (data.equipment == null || data.equipment is map) &&
             (data.diveNumber == null || data.diveNumber is number && data.diveNumber >= 0 && data.diveNumber <= 100000) &&
             (data.rating == null || (data.rating is number && data.rating >= 0 && data.rating <= 5)) &&
             (data.maxDepth == null || data.maxDepth is number && data.maxDepth >= 4 && data.maxDepth <= 60) &&
             (data.avgDepth == null || data.avgDepth is number && data.avgDepth >= 0 && data.avgDepth <= data.maxDepth) &&
             (data.duration == null || data.duration is number && data.duration >= 1 && data.duration <= 300) &&
             (data.visibility == null || data.visibility is number && data.visibility >= 0 && data.visibility <= 80) &&
             (data.waterTemp == null || data.waterTemp is number && data.waterTemp >= 10 && data.waterTemp <= 40) &&
             (data.oxygenPercent == null || data.oxygenPercent is number && data.oxygenPercent >= 21 && data.oxygenPercent <= 40) &&
             (data.startPressure == null || data.startPressure is number && data.startPressure >= 0 && data.startPressure <= 300) &&
             (data.endPressure == null || data.endPressure is number && data.endPressure >= 0 && data.endPressure <= 300) &&
             (data.notes == null || data.notes is string && data.notes.size() <= 2000) &&
             (data.marineLife == null || data.marineLife is list && data.marineLife.size() <= 20) &&
             (data.media == null || data.media is list && data.media.size() <= 20) &&
             (data.siteConditions == null || isValidDiveLogSiteConditions(data.siteConditions)) &&
             (data.speciesObservations == null || data.speciesObservations is list && data.speciesObservations.size() <= 40) &&
             (data.reefHealthObservations == null || data.reefHealthObservations is list && data.reefHealthObservations.size() <= 20) &&
             (data.debrisObservations == null || data.debrisObservations is list && data.debrisObservations.size() <= 20) &&
             (data.observationMetadata == null || isValidObservationMetadata(data.observationMetadata)) &&
             (data.updatedAt == null || data.updatedAt is string) &&
             (data.createdAt == null || data.createdAt is string);
    }

    function isValidDiveLogSiteConditions(data) {
      return data is map &&
             (data.visibilityMeters == null || data.visibilityMeters is number && data.visibilityMeters >= 0 && data.visibilityMeters <= 80) &&
             (data.current == null || data.current in ['none', 'mild', 'moderate', 'strong', 'very strong', 'unknown']) &&
             (data.currentDirection == null || data.currentDirection in ['incoming', 'outgoing', 'cross', 'variable', 'none', 'unknown']) &&
             (data.surge == null || data.surge in ['none', 'mild', 'moderate', 'strong', 'unknown']) &&
             (data.waterTempC == null || data.waterTempC is number && data.waterTempC >= 10 && data.waterTempC <= 40) &&
             (data.thermoclineDepthMeters == null || data.thermoclineDepthMeters is number && data.thermoclineDepthMeters >= 0 && data.thermoclineDepthMeters <= 60) &&
             (data.surfaceConditions == null || data.surfaceConditions in ['calm', 'choppy', 'rough', 'unknown']) &&
             (data.weatherNotes == null || data.weatherNotes is string && data.weatherNotes.size() <= 500) &&
             (data.entryExitDifficulty == null || data.entryExitDifficulty in ['easy', 'manageable', 'challenging', 'hazardous', 'unknown']) &&
             (data.hazards == null || data.hazards is list && data.hazards.size() <= 10) &&
             (data.hazardNotes == null || data.hazardNotes is string && data.hazardNotes.size() <= 500) &&
             (data.reportTime == null || data.reportTime is string);
    }

    function isValidSiteConditionReport(data) {
      return data is map &&
             (data.visibilityMeters == null || data.visibilityMeters is number && data.visibilityMeters >= 0 && data.visibilityMeters <= 80) &&
             data.current in ['none', 'mild', 'moderate', 'strong', 'very strong', 'unknown'] &&
             (data.currentDirection == null || data.currentDirection in ['incoming', 'outgoing', 'cross', 'variable', 'none', 'unknown']) &&
             (data.surge == null || data.surge in ['none', 'mild', 'moderate', 'strong', 'unknown']) &&
             (data.waterTempC == null || data.waterTempC is number && data.waterTempC >= 10 && data.waterTempC <= 40) &&
             (data.thermoclineDepthMeters == null || data.thermoclineDepthMeters is number && data.thermoclineDepthMeters >= 0 && data.thermoclineDepthMeters <= 60) &&
             (data.surfaceConditions == null || data.surfaceConditions in ['calm', 'choppy', 'rough', 'unknown']) &&
             (data.weatherNotes == null || data.weatherNotes is string && data.weatherNotes.size() <= 500) &&
             (data.entryExitDifficulty == null || data.entryExitDifficulty in ['easy', 'manageable', 'challenging', 'hazardous', 'unknown']) &&
             (data.hazards == null || data.hazards is list && data.hazards.size() <= 10) &&
             (data.hazardNotes == null || data.hazardNotes is string && data.hazardNotes.size() <= 500) &&
             data.reportTime is string;
    }

    function isValidSiteConditionPublicReport(data) {
      return data is map &&
             data.id is string &&
             data.siteId is string &&
             data.siteId.size() <= 128 &&
             data.siteName is string &&
             data.siteName.size() <= 100 &&
             data.atoll is string &&
             data.sourceDiveLogId == data.id &&
             data.submittedBy == request.auth.uid &&
             isValidSiteConditionReport(data) &&
             (data.island == null || data.island is string && data.island.size() <= 100) &&
             (data.contributorRole == null || data.contributorRole in ['recreational-diver', 'verified-contributor', 'dive-professional', 'dive-centre-manager', 'marine-science-reviewer', 'platform-admin']) &&
             (data.reefHealthSignals == null || data.reefHealthSignals is list && data.reefHealthSignals.size() <= 20) &&
             (data.debrisSignals == null || data.debrisSignals is list && data.debrisSignals.size() <= 20) &&
             (data.speciesCount == null || data.speciesCount is number && data.speciesCount >= 0 && data.speciesCount <= 40) &&
             (data.mediaEvidenceCount == null || data.mediaEvidenceCount is number && data.mediaEvidenceCount >= 0 && data.mediaEvidenceCount <= 20) &&
             data.verificationStatus in ['unverified', 'needs review', 'verified'] &&
             data.privacy in ['public aggregate', 'hide diver identity'] &&
             data.createdAt is string;
    }

    function isValidObservationMetadata(data) {
      return data is map &&
             data.source in ['diver'] &&
             data.verificationStatus in ['unverified', 'needs review', 'verified'] &&
             data.privacy in ['public aggregate', 'hide diver identity', 'sensitive location'];
    }

    function isValidObservationCatalog(data) {
      return data is map &&
             data.options is list &&
             data.options.size() <= 50 &&
             (data.label == null || data.label is string && data.label.size() <= 80) &&
             (data.sortOrder == null || data.sortOrder is number) &&
             (data.updatedAt == null || data.updatedAt is string);
    }

    function isValidAtoll(data) {
      return data is map &&
             data.name is string &&
             data.name.size() > 0 &&
             data.name.size() <= 80 &&
             (data.sortOrder == null || data.sortOrder is number) &&
             (data.updatedAt == null || data.updatedAt is string);
    }

    function isValidDiveSiteSuggestion(data, submitterId) {
      return data is map &&
             data.siteName is string &&
             data.siteName.size() > 0 &&
             data.siteName.size() <= 100 &&
             data.atoll is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.submittedBy == submitterId &&
             data.submittedAt is string &&
             (data.siteId == null || data.siteId is string && data.siteId.size() <= 128) &&
             (data.proposedDescription == null || data.proposedDescription is string && data.proposedDescription.size() <= 1000) &&
             (data.proposedSite == null || data.proposedSite is map) &&
             (data.reviewedBy == null || data.reviewedBy is string) &&
             (data.reviewedAt == null || data.reviewedAt is string) &&
             (data.reviewerNotes == null || data.reviewerNotes is string && data.reviewerNotes.size() <= 500);
    }

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             (data.email == null || data.email is string && data.email.size() <= 128) &&
             (data.name == null || data.name is string && data.name.size() <= 128) &&
             (data.role == null || data.role in ['recreational-diver', 'verified-contributor', 'dive-professional', 'dive-centre-manager', 'marine-science-reviewer', 'platform-admin']) &&
             (data.accessStatus == null || data.accessStatus in ['active', 'pending', 'disabled', 'invited']) &&
             (data.photoURL == null || data.photoURL is string && data.photoURL.size() <= 4096) &&
             (data.homeCountry == null || data.homeCountry is string && data.homeCountry.size() <= 80) &&
             (data.certificationProfile == null || isValidCertificationProfile(data.certificationProfile)) &&
             (data.units == null || data.units in ['metric', 'imperial']) &&
             (data.createdAt == null || data.createdAt is string) &&
             (data.updatedAt == null || data.updatedAt is string);
    }

    function isValidAppSettings(data) {
      return data is map &&
             (data.appName == null || data.appName is string && data.appName.size() <= 80) &&
             (data.contributionReviewRequired == null || data.contributionReviewRequired is bool) &&
             (data.sketchGenerationEnabled == null || data.sketchGenerationEnabled is bool) &&
             (data.defaultSketchInstructionsFromDescription == null || data.defaultSketchInstructionsFromDescription is bool) &&
             (data.speciesObservationReviewRequired == null || data.speciesObservationReviewRequired is bool) &&
             (data.publicDiveDataDefault == null || data.publicDiveDataDefault in ['private', 'public aggregate']) &&
             (data.dataExportEnabled == null || data.dataExportEnabled is bool) &&
             (data.updatedBy == null || data.updatedBy is string) &&
             (data.updatedAt == null || data.updatedAt is string);
    }

    function isValidProSubscription(data) {
      return data is map &&
             data.userId is string &&
             data.tier in ['free', 'individual-diver-pro', 'dive-centre-pro'] &&
             data.status in ['inactive', 'pending', 'active', 'cancelled', 'expired'] &&
             (data.diveCentreId == null || data.diveCentreId is string && data.diveCentreId.size() <= 128) &&
             (data.diveCentreName == null || data.diveCentreName is string && data.diveCentreName.size() <= 120) &&
             (data.provider == null || data.provider == 'bank-of-maldives') &&
             (data.sourceTransactionId == null || data.sourceTransactionId is string && data.sourceTransactionId.size() <= 128) &&
             (data.currentPeriodStart == null || data.currentPeriodStart is string) &&
             (data.currentPeriodEnd == null || data.currentPeriodEnd is string) &&
             (data.verifiedAt == null || data.verifiedAt is string) &&
             (data.verifiedBy == null || data.verifiedBy is string) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidPaymentTransaction(data) {
      return data is map &&
             data.userId == request.auth.uid &&
             data.provider == 'bank-of-maldives' &&
             data.tier in ['individual-diver-pro', 'dive-centre-pro'] &&
             data.status == 'pending' &&
             data.amountMvr is number &&
             data.amountMvr > 0 &&
             data.currency == 'MVR' &&
             data.paymentMode in ['payment-request', 'payment-gateway'] &&
             (data.externalReference == null || data.externalReference is string && data.externalReference.size() <= 128) &&
             (data.externalPaymentUrl == null || data.externalPaymentUrl is string && data.externalPaymentUrl.size() <= 1024) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidDivePlan(data) {
      return data is map &&
             data.id is string &&
             data.ownerId is string &&
             data.planType in ['individual', 'dive-centre'] &&
             data.siteId is string && data.siteId.size() <= 128 &&
             data.siteName is string && data.siteName.size() <= 120 &&
             data.atoll is string && data.atoll.size() <= 80 &&
             data.island is string && data.island.size() <= 100 &&
             data.plannedDate is string && data.plannedDate.size() == 10 &&
             data.plannedTime is string && data.plannedTime.size() <= 20 &&
             data.plannedDepthMeters is number && data.plannedDepthMeters >= 4 && data.plannedDepthMeters <= 60 &&
             data.plannedBottomTimeMinutes is number && data.plannedBottomTimeMinutes >= 1 && data.plannedBottomTimeMinutes <= 300 &&
             data.gasType is string && data.gasType.size() <= 40 &&
             data.participants is list && data.participants.size() <= 60 &&
             data.equipmentChecklist is list && data.equipmentChecklist.size() <= 40 &&
             data.safetyChecklist is list && data.safetyChecklist.size() <= 40 &&
             data.status in ['draft', 'confirmed', 'completed', 'cancelled'] &&
             (data.diveCentreId == null || data.diveCentreId is string && data.diveCentreId.size() <= 128) &&
             (data.diveCentreName == null || data.diveCentreName is string && data.diveCentreName.size() <= 120) &&
             (data.buddyDetails == null || data.buddyDetails is string && data.buddyDetails.size() <= 500) &&
             (data.boatName == null || data.boatName is string && data.boatName.size() <= 100) &&
             (data.assignedGuide == null || data.assignedGuide is string && data.assignedGuide.size() <= 120) &&
             (data.assignedInstructor == null || data.assignedInstructor is string && data.assignedInstructor.size() <= 120) &&
             (data.emergencyContact == null || data.emergencyContact is string && data.emergencyContact.size() <= 300) &&
             (data.nearestSupport == null || data.nearestSupport is string && data.nearestSupport.size() <= 300) &&
             (data.operationalNotes == null || data.operationalNotes is string && data.operationalNotes.size() <= 2000) &&
             (data.briefingNotes == null || data.briefingNotes is string && data.briefingNotes.size() <= 2000) &&
             (data.emergencyPlan == null || data.emergencyPlan is string && data.emergencyPlan.size() <= 2000) &&
             (data.duplicatedFromPlanId == null || data.duplicatedFromPlanId is string && data.duplicatedFromPlanId.size() <= 128) &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    function isValidCertificationProfile(data) {
      return data is map &&
             data.keys().hasOnly(['agency', 'level', 'certificationNumber', 'issueDate', 'instructorName']) &&
             (data.agency == null || data.agency is string && data.agency.size() <= 80) &&
             (data.level == null || data.level is string && data.level.size() <= 120) &&
             (data.certificationNumber == null || data.certificationNumber is string && data.certificationNumber.size() <= 80) &&
             (data.issueDate == null || data.issueDate is string && data.issueDate.size() <= 20) &&
             (data.instructorName == null || data.instructorName is string && data.instructorName.size() <= 128);
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /diveSites/{siteId} {
      allow read: if true;
      allow create: if isSignedIn() && canPublishDiveSiteInfo() && isValidId(siteId) && isValidDiveSite(incoming()) && incoming().keys().hasAll(['name', 'atoll', 'difficulty']) && incoming().keys().size() >= 3;
      allow update: if isSignedIn() && canPublishDiveSiteInfo() && isValidId(siteId) && isValidDiveSite(incoming()) &&
        incoming().id == existing().id;
      allow delete: if isAdmin();
    }

    match /diveSiteEditSuggestions/{suggestionId} {
      allow get: if isSignedIn() && isValidId(suggestionId) && (
        resource.data.submittedBy == request.auth.uid || canReviewDiveSiteSuggestions()
      );
      allow list: if isSignedIn() && canReviewDiveSiteSuggestions();
      allow create: if isSignedIn() &&
        isValidId(suggestionId) &&
        isValidDiveSiteSuggestion(incoming(), request.auth.uid) &&
        incoming().status == 'pending';
      allow update: if isSignedIn() &&
        canReviewDiveSiteSuggestions() &&
        isValidDiveSiteSuggestion(incoming(), existing().submittedBy) &&
        incoming().submittedBy == existing().submittedBy &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reviewedBy', 'reviewedAt', 'reviewerNotes']);
      allow delete: if isAdmin();
    }

    match /marineLife/{speciesId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(speciesId) && isValidMarineLife(incoming()) && incoming().keys().hasAll(['name', 'scientificName', 'category']) && incoming().keys().size() >= 3;
      allow update: if isSignedIn() && isValidId(speciesId) && isValidMarineLife(incoming()) && (
        isAdmin() || (incoming().id == existing().id && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'category', 'rarity', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    match /observationCatalog/{catalogId} {
      allow read: if true;
      allow create, update: if isAdmin() &&
        catalogId in ['currentStrength', 'currentDirection', 'surge', 'surfaceConditions', 'entryExitDifficulty', 'hazards', 'reefHealth', 'debris'] &&
        isValidObservationCatalog(incoming());
      allow delete: if isAdmin();
    }

    match /siteConditionReports/{reportId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        isValidId(reportId) &&
        incoming().id == reportId &&
        isValidSiteConditionPublicReport(incoming());
      allow update: if isSignedIn() &&
        isValidId(reportId) &&
        existing().submittedBy == request.auth.uid &&
        incoming().id == reportId &&
        isValidSiteConditionPublicReport(incoming());
      allow delete: if isAdmin();
    }

    match /appSettings/{settingsId} {
      allow read: if isAdmin() && isValidId(settingsId);
      allow write: if isAdmin() && isValidId(settingsId) && isValidAppSettings(incoming());
    }

    match /proSubscriptions/{userId} {
      allow read: if (isOwner(userId) || isAdmin()) && isValidId(userId);
      allow create, update, delete: if isAdmin() && isValidId(userId) && isValidProSubscription(incoming()) && incoming().userId == userId;
    }

    match /paymentTransactions/{transactionId} {
      allow get, list: if isSignedIn() && isValidId(transactionId) && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(transactionId) && isValidPaymentTransaction(incoming());
      allow update, delete: if isAdmin() && isValidId(transactionId);
    }

    match /divePlans/{planId} {
      allow get, list: if isSignedIn() && isValidId(planId) && (
        isAdmin() ||
        resource.data.ownerId == request.auth.uid ||
        (resource.data.planType == 'dive-centre' && hasDiveCentrePro(request.auth.uid, resource.data.diveCentreId))
      );
      allow create: if isSignedIn() &&
        isValidId(planId) &&
        isValidDivePlan(incoming()) &&
        incoming().id == planId &&
        (
          (incoming().planType == 'individual' && incoming().ownerId == request.auth.uid && hasIndividualPro(request.auth.uid)) ||
          (incoming().planType == 'dive-centre' && incoming().ownerId == request.auth.uid && hasDiveCentrePro(request.auth.uid, incoming().diveCentreId))
        );
      allow update: if isSignedIn() &&
        isValidId(planId) &&
        isValidDivePlan(incoming()) &&
        incoming().id == planId &&
        incoming().ownerId == existing().ownerId &&
        incoming().createdAt == existing().createdAt &&
        (
          isAdmin() ||
          (existing().planType == 'individual' && existing().ownerId == request.auth.uid && hasIndividualPro(request.auth.uid)) ||
          (existing().planType == 'dive-centre' && hasDiveCentrePro(request.auth.uid, existing().diveCentreId))
        );
      allow delete: if isAdmin();
    }

    match /atolls/{atollId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(atollId) && isValidAtoll(incoming());
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list, create, update, delete: if false;
    }

    match /diveLogs/{logId} {
      allow get: if isSignedIn() && isValidId(logId) && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(logId) && isValidDiveLog(incoming()) && 
                    incoming().keys().hasAll(['userId', 'date', 'siteId']) && 
                    incoming().userId == request.auth.uid;
      allow update: if isOwner(existing().userId) && isValidId(logId) && isValidDiveLog(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['id', 'date', 'startTime', 'siteId', 'customSiteName', 'atoll', 'island', 'current', 'entryType', 'diveTypes', 'gasType', 'tankSize', 'sac', 'surfaceInterval', 'safetyStop', 'buddyNames', 'diveCenter', 'instructorName', 'isVerified', 'equipment', 'diveNumber', 'rating', 'maxDepth', 'avgDepth', 'duration', 'visibility', 'waterTemp', 'oxygenPercent', 'startPressure', 'endPressure', 'notes', 'marineLife', 'media', 'siteConditions', 'speciesObservations', 'reefHealthObservations', 'debrisObservations', 'observationMetadata', 'syncStatus', 'updatedAt']);
      allow delete: if isOwner(existing().userId) && isValidId(logId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming()) && incoming().uid == userId && incoming().role == null;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserProfile(incoming()) && 
                    incoming().uid == userId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'photoURL', 'homeCountry', 'units', 'certificationProfile', 'updatedAt']);
    }

  }
}
