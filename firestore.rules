rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function adminDoc() { return exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function roles() { return adminDoc() ? get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.roles : []; }
    function hasRole(role) { return signedIn() && role in roles(); }
    function isAdmin() { return hasRole('admin'); }
    function kbStaff() { return hasRole('admin') || hasRole('kb_uploader') || hasRole('kb_reviewer'); }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);
      match /fieldGuidePhotos/{photoId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /diveLogs/{logId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /diveSites/{siteId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /marineLife/{speciesId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /teamDives/{teamDiveId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /teamDiveParticipants/{participantId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, delete: if signedIn();
      allow update: if signedIn() && (
        isAdmin() ||
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'logStatus', 'personalLogId', 'updatedAt'])
      );
    }

    match /admins/{uid} { allow read: if isOwner(uid); allow write: if false; }
    match /knowledge_documents/{id} { allow read: if kbStaff(); allow write: if false; }
    match /knowledge_processing_jobs/{id} { allow read: if kbStaff(); allow write: if false; }
    match /knowledge_document_chunks/{id} { allow read: if kbStaff(); allow write: if false; }
    match /proposed_data_updates/{id} { allow read: if kbStaff(); allow write: if false; }
    match /review_decisions/{id} { allow read: if kbStaff(); allow write: if false; }
    match /knowledge_audit_events/{id} { allow read: if kbStaff(); allow write: if false; }
    match /user_api_keys/{id} { allow read, write: if false; }
    match /ai_key_usage/{id} { allow read, write: if false; }
    match /system/{id} { allow read, write: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
