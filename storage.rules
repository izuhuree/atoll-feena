rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        firestore.exists(/databases/atollfeena/documents/admins/$(request.auth.uid)) ||
        userRole() == 'platform-admin'
      );
    }

    function userRole() {
      return isSignedIn() &&
             firestore.exists(/databases/atollfeena/documents/users/$(request.auth.uid))
        ? firestore.get(/databases/atollfeena/documents/users/$(request.auth.uid)).data.role
        : 'recreational-diver';
    }

    function canGenerateDiveSiteSketches() {
      return isAdmin() || userRole() in [
        'dive-professional',
        'dive-centre-manager',
        'marine-science-reviewer',
        'platform-admin'
      ];
    }

    match /users/{userId}/profile/{fileName} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() &&
                   request.auth.uid == userId &&
                   request.resource.size < 5 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
    }

    // AI-generated dive-site sketches. Publicly readable so non-admins see
    // the cached image; trusted reviewers can generate; admins bypass object
    // constraints so they can resolve failed uploads and repair app media.
    match /divesite-sketches/{siteId} {
      allow read: if true;
      allow write: if isAdmin() || (
        canGenerateDiveSiteSketches() &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*')
      );
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
